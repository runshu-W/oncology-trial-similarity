# macOS and editor noise
.DS_Store
*.swp
*.swo

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/

# Codex / local workflow
.superpowers/
.worktrees/
.understand-anything/
*.Rhistory

# Large runtime artifacts
artifacts/
*.jsonl
*.npz
*.pt
*.pth
*.pkl
*.joblib
**/pipeline_results.jsonl
**/trial_embeddings.npz
**/hashing_index/

# Transient run logs
scripts/**/*.log

# Raw ClinicalTrials.gov exports and local PDFs
Oncology_All_Trials/
**/NCT*_data.json
**/Study_Protocol.pdf
**/Statistical_Analysis_Plan.pdf

# Large generated manuscript media outside the lightweight results package
docs/figures/
*.pdf
*.tif
*.tiff

# LaTeX build outputs
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.log
*.out
*.run.xml
*.synctex.gz
*.toc
*.xdv

# Keep lightweight manuscript evidence package
!results/
!results/**

# Manuscript source lives in manuscript/ ; keep figure assets despite the
# global *.pdf rule, but leave the regenerable compiled PDFs untracked.
!manuscript/figures/*.pdf
manuscript/manuscript_full_draft_pharm_stats.pdf
manuscript/supplement.pdf
*.bak
*.tmp
